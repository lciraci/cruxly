# News API - Get your free API key at https://newsapi.org/register
# Free tier: 100 requests/day, 15 requests/15 min
# NOTE: Free tier only works on localhost, not in production
NEWS_API_KEY=your_newsapi_key_here

# Anthropic API - Get your API key at https://console.anthropic.com/
# Pay-per-use: ~$0.003 per analysis with Haiku, ~$0.03 with Sonnet
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google AdSense - Get your publisher ID at https://adsense.google.com
# Format: ca-pub-XXXXXXXXXX (leave empty to disable ads)
NEXT_PUBLIC_ADSENSE_ID=

# PostHog Analytics - Create a free project at https://eu.posthog.com (EU region)
# Project Settings -> copy the "Project API Key" (starts with phc_)
# Cookieless mode: leave the key empty to disable tracking entirely
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
